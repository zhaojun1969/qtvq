{
  "name": "qtvq",
  "version": "1.0.0",
  "description": "我心永恒-Q问 情感避坑与AI智慧问答",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx wrangler pages dev . --port 8788",
    "serve": "python -m http.server 8080",
    "deploy": "powershell -ExecutionPolicy Bypass -File tools/scripts/deploy.ps1 -SkipKv",
    "deploy:all": "powershell -ExecutionPolicy Bypass -File tools/scripts/deploy-all.ps1",
    "deploy:api-only": "powershell -ExecutionPolicy Bypass -File tools/scripts/deploy-all.ps1 -SkipStatic",
    "sync:static": "powershell -ExecutionPolicy Bypass -File tools/scripts/sync-static-from-windows.ps1",
    "deploy:api:linux": "bash tools/scripts/deploy-api.sh",
    "deploy:api-only:linux": "bash tools/scripts/deploy-api.sh",
    "deploy:site": "npx wrangler pages deploy . --project-name=qtvq-site",
    "setup:kv": "powershell -ExecutionPolicy Bypass -File tools/scripts/setup-kv.ps1",
    "deploy:full": "powershell -ExecutionPolicy Bypass -File tools/scripts/deploy.ps1",
    "post-deploy": "powershell -ExecutionPolicy Bypass -File tools/scripts/post-deploy.ps1",
    "dashboard": "powershell -ExecutionPolicy Bypass -File tools/scripts/open-dashboard.ps1",
    "bind:domain": "powershell -ExecutionPolicy Bypass -File tools/scripts/bind-custom-domain.ps1",
    "github:publish": "powershell -ExecutionPolicy Bypass -File tools/scripts/publish-github.ps1",
    "context:build": "powershell -ExecutionPolicy Bypass -File tools/scripts/build-context-bundle.ps1",
    "context:upload": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-obs.ps1",
    "sync:obs": "powershell -ExecutionPolicy Bypass -File tools/scripts/sync-obs.ps1",
    "backup:publish": "python tools/scripts/publish-backup-snapshots.py",
    "sync:obsidian": "powershell -ExecutionPolicy Bypass -File tools/scripts/sync-obsidian.ps1",
    "git:push-all": "powershell -ExecutionPolicy Bypass -File tools/scripts/push-all.ps1",
    "check:live": "powershell -ExecutionPolicy Bypass -File tools/scripts/check-live.ps1",
    "mail:secrets": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-mail-secrets.ps1",
    "wechat:secrets": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-wechat-secrets.ps1",
    "wechat:secrets:linux": "bash tools/scripts/upload-wechat-secrets.sh",
    "wechat:test-sign": "node tools/scripts/test-wechat-sign.mjs",
    "speech:secrets": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-speech-secrets.ps1",
    "build:rag": "node tools/scripts/build-rag-index.js",
    "logo:export": "node tools/scripts/export-logo-png.js",
    "package:static": "powershell -ExecutionPolicy Bypass -File tools/scripts/package-static.ps1",
    "upload:static-obs": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-static-obs.ps1",
    "uni:install": "cd apps/qtvq-uni && npm install",
    "uni:dev:h5": "cd apps/qtvq-uni && npm run dev:h5",
    "uni:dev:mp-weixin": "cd apps/qtvq-uni && npm run dev:mp-weixin",
    "uni:dev:mp-alipay": "cd apps/qtvq-uni && npm run dev:mp-alipay",
    "uni:build:weixin": "cd apps/qtvq-uni && npm run build:mp-weixin",
    "uni:build:alipay": "cd apps/qtvq-uni && npm run build:mp-alipay",
    "uni:sync-static": "node tools/scripts/sync-uni-static.js",
    "kv:create": "npx wrangler kv namespace create QTVQ_KV && npx wrangler kv namespace create QTVQ_KV --preview",
    "preview": "npx wrangler pages dev . --port 8788 --local-protocol=http"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "wrangler": "^4.96.0"
  }
}
