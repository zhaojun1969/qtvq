{
  "name": "qtvq",
  "version": "1.0.0",
  "description": "我心永恒-Q问 情感避坑与AI智慧问答",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx wrangler pages dev . --port 8788",
    "serve": "python -m http.server 8080",
    "deploy": "wrangler pages deploy . --project-name=qtvq-api",
    "deploy:site": "wrangler pages deploy . --project-name=qtvq-site",
    "setup:kv": "powershell -ExecutionPolicy Bypass -File tools/scripts/setup-kv.ps1",
    "deploy:full": "powershell -ExecutionPolicy Bypass -File tools/scripts/deploy.ps1",
    "post-deploy": "powershell -ExecutionPolicy Bypass -File tools/scripts/post-deploy.ps1",
    "dashboard": "powershell -ExecutionPolicy Bypass -File tools/scripts/open-dashboard.ps1",
    "bind:domain": "powershell -ExecutionPolicy Bypass -File tools/scripts/bind-custom-domain.ps1",
    "github:publish": "powershell -ExecutionPolicy Bypass -File tools/scripts/publish-github.ps1",
    "context:build": "powershell -ExecutionPolicy Bypass -File tools/scripts/build-context-bundle.ps1",
    "context:upload": "powershell -ExecutionPolicy Bypass -File tools/scripts/upload-obs.ps1",
    "git:push-all": "powershell -ExecutionPolicy Bypass -File tools/scripts/push-all.ps1",
    "check:live": "powershell -ExecutionPolicy Bypass -File tools/scripts/check-live.ps1",
    "uni:install": "cd apps/qtvq-uni && npm install",
    "uni:dev:h5": "cd apps/qtvq-uni && npm run dev:h5",
    "uni:dev:mp-weixin": "cd apps/qtvq-uni && npm run dev:mp-weixin",
    "kv:create": "wrangler kv namespace create QTVQ_KV && wrangler kv namespace create QTVQ_KV --preview",
    "preview": "npx wrangler pages dev . --port 8788 --local-protocol=http"
  }
}
