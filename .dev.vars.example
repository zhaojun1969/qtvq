# 复制为 .dev.vars 供 wrangler pages dev 使用
# 生产环境在 Cloudflare Pages → Settings → Environment variables 配置

PAYMENT_ADMIN_KEY=请替换为强随机密钥

# OSS 动态数据备份（与 obs.env 一致，Secret 类型）
# OSS_ACCESS_KEY_ID=
# OSS_SECRET_ACCESS_KEY=
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_BUCKET=qtvq
# OSS_BACKUP_PREFIX=qtvq/backup/

# ---- 联系客服 · 邮件通知（二选一）----

# 方式 A：SMTP（推荐，阿里云/腾讯企业邮）
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=qtvq@qtvq.cn
SMTP_PASS=请填写SMTP授权码或邮箱密码
SMTP_FROM=qtvq@qtvq.cn
SMTP_TO=qtvq@qtvq.cn

# 方式 B：Resend HTTP API（需先在 Resend 验证发信域名）
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=Q问 <noreply@qtvq.cn>
# MAIL_TO=qtvq@qtvq.cn

# ---- 语音输入 · 阿里云一句话识别（NLS）----
# 控制台：https://nls-portal.console.aliyun.com/
# 创建项目 → 获取 AppKey；AccessKey 可与 OSS 共用
# NLS_APP_KEY=你的NLS_AppKey

# ---- 微信支付 V3（见 docs/PAYMENT-WECHAT-API.md）----
WECHAT_MCH_ID=1113936939
WECHAT_PAY_NOTIFY_URL=https://qtvq-api.pages.dev/api/payment/wechat/notify
# 以下在 pay.weixin.qq.com → 账户中心 → API 安全 / 产品中心 获取后填写
# WECHAT_APP_ID=                    # 小程序或公众号 AppID，须与商户号绑定
# WECHAT_API_V3_KEY=                  # APIv3 密钥（32 位）
# WECHAT_MCH_SERIAL=                  # 商户 API 证书序列号
# WECHAT_MCH_PRIVATE_KEY=             # 商户私钥 PEM（可单行，\\n 换行）
# WECHAT_PLATFORM_PUBLIC_KEY=         # 平台公钥（验签回调，生产建议）
# WECHAT_MINI_APP_SECRET=             # 小程序 AppSecret（微信登录 / 找回密码，微信公众平台 → 开发管理 → 开发设置）
# ---- 微信开放平台 · 网站应用扫码登录 ----
# WECHAT_OPEN_APP_ID=wxc4b560055c1978dc   # 开放平台网站应用「Q问」
# WECHAT_OPEN_APP_SECRET=             # 网站应用 AppSecret
# WECHAT_OPEN_REDIRECT_URI=https://qtvq.cn/wechat-callback.html
