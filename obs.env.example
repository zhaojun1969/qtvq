# 复制为 obs.env 并填写（勿提交 Git）
# 华为云 OBS 示例；若使用 S3 兼容端点请改 OBS_ENDPOINT

OBS_ACCESS_KEY_ID=你的AK
OBS_SECRET_ACCESS_KEY=你的SK
OBS_ENDPOINT=https://obs.cn-north-4.myhuaweicloud.com
OBS_BUCKET=qtvq-backup
# 对象前缀，如 qtvq/context/
OBS_PREFIX=qtvq/context/
# 动态 API 备份（Cloudflare KV → OSS，供前端降级读取）
OSS_BACKUP_PREFIX=qtvq/backup/
OSS_PUBLIC_BASE=https://qtvq.oss-cn-beijing.aliyuncs.com/qtvq/backup
